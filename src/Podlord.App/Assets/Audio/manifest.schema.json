{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PodlordAudioManifest",
  "type": "object",
  "required": ["version", "sounds", "music", "defaults"],
  "properties": {
    "$schema": { "type": "string" },
    "version": { "type": "integer", "minimum": 1 },
    "description": { "type": "string" },
    "sounds": {
      "type": "object",
      "description": "Map of semantic role -> array of file paths relative to this manifest. Multiple paths = shuffled. Empty array = silent.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "music": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["tracks"],
        "properties": {
          "shuffle": { "type": "boolean", "default": true },
          "loop": { "type": "boolean", "default": true },
          "tracks": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "defaults": {
      "type": "object",
      "properties": {
        "master_volume": { "type": "number", "minimum": 0, "maximum": 1 },
        "ui_volume": { "type": "number", "minimum": 0, "maximum": 1 },
        "alert_volume": { "type": "number", "minimum": 0, "maximum": 1 },
        "voice_volume": { "type": "number", "minimum": 0, "maximum": 1 },
        "music_volume": { "type": "number", "minimum": 0, "maximum": 1 },
        "muted_categories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "switch_music_on_incident": { "type": "boolean" }
      }
    }
  }
}
